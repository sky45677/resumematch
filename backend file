from sentence_transformers import SentenceTransformer
import spacy
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
import re

# Initialize models (singleton pattern)
_model = None
_nlp = None

def get_model():
    global _model
    if _model is None:
        _model = SentenceTransformer('all-MiniLM-L6-v2')
    return _model

def get_nlp():
    global _nlp
    if _nlp is None:
        _nlp = spacy.load("en_core_web_lg")
    return _nlp

def calculate_match_score(resume_text, job_description):
    """Calculate semantic similarity score between resume and job description"""
    model = get_model()
    embeddings = model.encode([resume_text, job_description])
    similarity = cosine_similarity([embeddings[0]], [embeddings[1]])[0][0]
    return round(similarity * 100, 2)

def extract_keywords(job_description, resume_text):
    """Extract missing keywords using spaCy"""
    nlp = get_nlp()
    
    # Process job description
    job_doc = nlp(job_description.lower())
    # Extract NOUN and PROPN tokens
    job_keywords = [token.lemma_ for token in job_doc if token.pos_ in ["NOUN", "PROPN"] and not token.is_stop and token.is_alpha]
    
    # Process resume
    resume_doc = nlp(resume_text.lower())
    resume_keywords = [token.lemma_ for token in resume_doc if token.pos_ in ["NOUN", "PROPN"] and not token.is_stop and token.is_alpha]
    
    # Find missing keywords
    job_keywords_set = set(job_keywords)
    resume_keywords_set = set(resume_keywords)
    missing = list(job_keywords_set - resume_keywords_set)
    
    # Count frequency in job description for sorting
    keyword_freq = {}
    for token in job_doc:
        if token.pos_ in ["NOUN", "PROPN"] and not token.is_stop and token.is_alpha:
            lemma = token.lemma_
            keyword_freq[lemma] = keyword_freq.get(lemma, 0) + 1
    
    # Sort missing keywords by frequency in job description (descending)
    missing_sorted = sorted(missing, key=lambda x: keyword_freq.get(x, 0), reverse=True)
    
    # Return top 15
    return missing_sorted[:15]

def generate_suggestions(resume_text, missing_keywords):
    """Generate rule-based improvement suggestions"""
    suggestions = []
    
    # Check resume length
    word_count = len(resume_text.split())
    if word_count < 300:
        suggestions.append("Add more detail to your experience")
    
    # Check missing keywords count
    if len(missing_keywords) > 10:
        suggestions.append("Add these skills to your resume")
    
    # Check for metrics/numbers
    if not re.search(r'\d+%|\$\d+|\d+\+|\d+x', resume_text):
        suggestions.append("Quantify achievements with numbers")
    
    # Check for action verbs
    action_verbs = {'led', 'built', 'improved', 'managed', 'created', 'developed', 'increased', 'reduced', 'optimized', 'delivered'}
    resume_lower = resume_text.lower()
    found_verbs = [verb for verb in action_verbs if verb in resume_lower]
    if len(found_verbs) < 2:
        suggestions.append("Add strong action verbs like led, built, improved, managed")
    
    return suggestions
