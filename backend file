class ScanHistorySerializer(serializers.ModelSerializer):
    job_title = serializers.SerializerMethodField()
    
    class Meta:
        model = ScanResult
        fields = ['id', 'resume_filename', 'job_title', 'match_score', 'created_at']
    
    def get_job_title(self, obj):
        # Return first 6 words of job description
        words = obj.job_description.split()[:6]
        return ' '.join(words) + ('...' if len(obj.job_description.split()) > 6 else '')
