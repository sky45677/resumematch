import os
from huggingface_hub import InferenceClient

def rewrite_resume(job_description, resume_text):
    """Rewrite resume using Hugging Face Inference API"""
    try:
        # Initialize client
        client = InferenceClient(token=os.getenv("HF_TOKEN"))
        
        # Define the prompt
        system_prompt = "You are an expert resume writer. Rewrite the provided resume to better match the job description. Keep all facts true. Use strong action verbs. Naturally incorporate missing keywords where relevant. Format output as clean plain text with sections: Summary, Experience, Skills, Education."
        user_prompt = f"JOB DESCRIPTION:\n{job_description}\n\nORIGINAL RESUME:\n{resume_text}\n\nRewrite the resume to maximize match for this job."
        
        # Call the API
        response = client.chat.completions.create(
            model="HuggingFaceH4/zephyr-7b-beta",
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            max_tokens=1000,
            temperature=0.7
        )
        
        return response.choices[0].message.content.strip()
    except Exception as e:
        # Fallback to original if API fails
        return f"Error generating rewrite: {str(e)}. Please try again later."
